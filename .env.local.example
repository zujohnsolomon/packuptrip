# Copy to .env.local and fill in real values.
# All of these must also be set in Vercel Dashboard → Settings → Environment Variables.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — bypasses RLS. DO NOT expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get from resend.com → API Keys. Domain must be verified.
RESEND_API_KEY=
EMAIL_FROM=Packuptrip <hello@packuptrip.com>

# ── Site URL ─────────────────────────────────────────────────────────────────
# Update to your production domain once DNS is live.
NEXT_PUBLIC_SITE_URL=https://packuptrip.com

# ── Anthropic (AI features) ───────────────────────────────────────────────────
# Powers E2 AI Itinerary Draft and F2 AI Concierge (Packy).
# Get from console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# ── Cron security ────────────────────────────────────────────────────────────
# Random secret — Vercel attaches it as Authorization: Bearer <CRON_SECRET>
# on every cron invocation. Generate with: openssl rand -hex 32
CRON_SECRET=
